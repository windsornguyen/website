{
  "name": "windsornguyen.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp --host 0.0.0.0 --port 5173",
    "build": "vp build",
    "preview": "vp preview --host 0.0.0.0 --port 4173",
    "test": "vp test --run",
    "test:smoke": "node --test tests/site-smoke.smoke.mjs",
    "lint": "vp lint . && markdownlint-cli2 \"**/*.{md,mdx}\" \"#node_modules\" \"#.output\" \"#dist\"",
    "format": "vp fmt --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}\" && prettier --write \"**/*.{md,mdx,css}\"",
    "check-format": "vp fmt --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}\" && prettier --check \"**/*.{md,mdx,css}\"",
    "typecheck": "tsgo --noEmit",
    "check": "vp lint . && markdownlint-cli2 \"**/*.{md,mdx}\" \"#node_modules\" \"#.output\" \"#dist\" && pnpm check-format && pnpm typecheck",
    "check:vp": "vp check ."
  },
